{
  "expo": {
    "name": "Interview Boat",
    "slug": "crackit",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "owner": "richa130013",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c4a6e"
    },
    "platforms": ["android"],
    "android": {
      "package": "com.interviewboat.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow Interview Boat to access your microphone for voice interviews."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fbaf971c-d2a1-4e2b-afe5-a9c22c05b3fa"
      }
    }
  }
}
